<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.platform.warranty.mapper.CommentMapper">
  <select id="selectAll" resultType="com.platform.warranty.domain.entity.Comment">
    SELECT *
    FROM comment
    <where>
        <!-- postId 不为 null -->
        <if test="dto.postId != null">
            AND post_id = #{dto.postId}
        </if>

        <!-- userId 不为 null -->
        <if test="dto.userId != null">
            AND user_id = #{dto.userId}
        </if>

        <!-- isDeleted 不为 null -->
        <if test="dto.isDeleted != null">
            AND is_deleted = #{dto.isDeleted}
        </if>

        <!-- keyword 不为 null 且非空字符串 -->
        <if test="dto.keyword != null and dto.keyword != ''">
            AND content LIKE CONCAT('%', #{dto.keyword}, '%')
        </if>
    </where>

    ORDER BY created_time DESC
</select>
</mapper>
